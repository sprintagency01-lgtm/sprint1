# =============================================================================
# Demo Gemini 3.1 Flash Live - configuración
# Copia este fichero a .env y rellena los valores reales.
# =============================================================================

# API key de Google AI Studio. Sácala en: https://aistudio.google.com/apikey
# El SDK google-genai la lee automáticamente desde GEMINI_API_KEY.
GEMINI_API_KEY=AIza...

# Modelo Live a usar. Default: gemini-3.1-flash-live-preview.
# Alternativas para A/B: gemini-2.5-flash-native-audio-preview-12-2025.
GEMINI_MODEL=gemini-3.1-flash-live-preview

# Voz nativa (multilingüe). Probar también: Charon, Puck, Fenrir, Aoede.
# Lista completa audible en https://aistudio.google.com/live
GEMINI_VOICE=Kore

# =============================================================================
# Backend de Sprintia (Railway). El demo llama a las MISMAS tools que ElevenLabs.
# =============================================================================

# URL pública del backend. Producción usa el custom domain.
BACKEND_URL=https://sprintiasolutions.com

# Tenant a usar para el demo. pelu_demo = peluquería de Marcos.
TENANT_ID=pelu_demo

# Secreto compartido con el backend para llamar a /tools/*.
# Es el MISMO TOOL_SECRET que está en el .env de la raíz del repo.
TOOL_SECRET=copialo-del-env-raiz

# Caller ID simulado (el demo es por micro, no por SIP).
# El backend lo usa como teléfono del cliente cuando crea la reserva.
CALLER_ID=+34600000000

# =============================================================================
# Audio (valores fijos del modelo, no toques salvo que sepas)
# =============================================================================
# Sample rate de entrada (lo que graba el micro y enviamos al modelo).
AUDIO_INPUT_SAMPLE_RATE=16000

# Sample rate de salida (lo que devuelve el modelo, FIJO en 24kHz).
AUDIO_OUTPUT_SAMPLE_RATE=24000

# Chunk de captura de micro en ms (50ms = 800 samples a 16kHz).
AUDIO_CHUNK_MS=50
