# ======= OpenAI =======
# Se usa para: (a) parse IA en el portal (texto libre → JSON de reserva) y
# (b) razonamiento del agente en modo CLI/diag. El bot productivo hoy es voz
# (ElevenLabs) — OpenAI deja de ser obligatorio para las llamadas.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# ======= ElevenLabs (voz - canal único) =======
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=
# ID del agente Conversational AI (se rellena tras ejecutar scripts/setup_elevenlabs_agent.py).
ELEVENLABS_AGENT_ID=
# Secreto compartido que ElevenLabs envía en el header X-Tool-Secret al llamar a
# los webhooks /tools/*. Genera uno con:
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
TOOL_SECRET=

# ======= Google Calendar =======
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/oauth/callback
DEFAULT_CALENDAR_ID=primary
DEFAULT_TIMEZONE=Europe/Madrid

# ======= App =======
DATABASE_URL=sqlite:///./data.db
TENANTS_FILE=./tenants.yaml
LOG_LEVEL=INFO
# Dónde guardar los tokens OAuth de Google. En local = .tokens/.
# En Railway con Volume: TOKENS_DIR=/app/data/.tokens
TOKENS_DIR=.tokens

# ======= CMS / panel de administración =======
# Primer login: se crea automáticamente al arrancar usando estas variables.
ADMIN_EMAIL=admin@tudominio.com
ADMIN_PASSWORD=cambia_esta_contraseña_segura

# Secreto para firmar las cookies de sesión. En producción genera una aleatoria:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
SESSION_SECRET=cambia_esto_en_produccion
