# ======= OpenAI =======
# Se usa para: (a) parse IA en el portal (texto libre → JSON de reserva) y
# (b) razonamiento del agente en modo CLI/diag. El bot productivo hoy es voz
# (ElevenLabs) — OpenAI deja de ser obligatorio para las llamadas.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# ======= ElevenLabs (voz - canal único) =======
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=
# ID del agente Conversational AI (se rellena tras ejecutar scripts/setup_elevenlabs_agent.py).
ELEVENLABS_AGENT_ID=
# Secreto compartido que ElevenLabs envía en el header X-Tool-Secret al llamar a
# los webhooks /tools/*. Genera uno con:
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
TOOL_SECRET=

# ======= Google Calendar =======
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Local dev: http://localhost:8000/oauth/callback
# Producción (custom domain): https://sprintiasolutions.com/oauth/callback
# Recordar: hay que registrar la URI en Google Cloud Console → Credentials → OAuth 2.0 Client.
GOOGLE_REDIRECT_URI=http://localhost:8000/oauth/callback
DEFAULT_CALENDAR_ID=primary
DEFAULT_TIMEZONE=Europe/Madrid

# ======= App =======
DATABASE_URL=sqlite:///./data.db
TENANTS_FILE=./tenants.yaml
LOG_LEVEL=INFO
# Dónde guardar los tokens OAuth de Google. En local = .tokens/.
# En Railway con Volume: TOKENS_DIR=/app/data/.tokens
TOKENS_DIR=.tokens

# ======= CMS / panel de administración =======
# Primer login: se crea automáticamente al arrancar usando estas variables.
ADMIN_EMAIL=admin@tudominio.com
ADMIN_PASSWORD=cambia_esta_contraseña_segura

# Secreto para firmar las cookies de sesión. En producción genera una aleatoria:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
SESSION_SECRET=cambia_esto_en_produccion

# ======= Leads landing: notificaciones y autorespuesta =======
# Alerta interna opcional. Puedes usar un Slack Incoming Webhook, Make/Zapier,
# o un email directo vía Resend.
LEAD_NOTIFY_WEBHOOK_URL=
LEAD_NOTIFY_EMAIL_TO=
# Email transaccional vía Resend. Necesario para LEAD_NOTIFY_EMAIL_TO y para
# autoresponder al lead.
RESEND_API_KEY=
LEAD_EMAIL_FROM=
LEAD_AUTOREPLY_ENABLED=false
LEAD_AUTOREPLY_SUBJECT=Hemos recibido tu solicitud en Sprintia
# Sincronización CRM/email marketing con Brevo.
BREVO_API_KEY=
BREVO_LIST_IDS=
BREVO_UPDATE_ENABLED=true
# Opcional: si creas atributos personalizados en Brevo, pon aquí sus nombres.
BREVO_COMPANY_ATTRIBUTE=COMPANY
BREVO_SECTOR_ATTRIBUTE=SECTOR
BREVO_COUNTRY_ATTRIBUTE=COUNTRY
BREVO_LEAD_ID_ATTRIBUTE=LEAD_ID
BREVO_SENDER_EMAIL=
BREVO_SENDER_NAME=Sprintia

# ======= Sync CMS → Google Sheets =======
# Cada cambio en /admin/clientes/* se replica automáticamente en una pestaña
# "Tenants" del Sheet de onboarding. Si ambas vars están vacías, el sync queda
# deshabilitado (la app sigue funcionando con normalidad).
#
# Setup completo en SHEETS_SYNC_SETUP.md. Resumen:
#   1. Crear Service Account en GCP, habilitar Google Sheets API.
#   2. Descargar el JSON de credenciales.
#   3. Compartir el Sheet con el email del Service Account (rol Editor).
#   4. Pegar el JSON entero (en una línea, escapado) en GOOGLE_SERVICE_ACCOUNT_JSON.
#   5. Pegar el ID del Sheet (parte larga del URL) en GOOGLE_SHEETS_ID.
GOOGLE_SHEETS_ID=
GOOGLE_SERVICE_ACCOUNT_JSON=
